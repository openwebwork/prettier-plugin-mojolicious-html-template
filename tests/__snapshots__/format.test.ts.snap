exports[`basic-html.html.ep 1`] = `
"
<!DOCTYPE html>
<html>
    <head>
        <title>Test Page</title>
    </head>
    <body>
        <div class="container">
            <p>Hello, world!</p>
        </div>
    </body>
</html>
"
`;

exports[`inline-blocks.html.ep 1`] = `
"
<div class="greeting">
    <p>Hello, <%= $name %>!</p>
    <p><%== $rawHtml %></p>
    <% my $count = scalar(@items); %>
    <p>You have <%= $count %> items.</p>
</div>
"
`;
